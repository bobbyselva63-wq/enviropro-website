@app.route("/admin/projects/add", methods=["POST"])
@login_required
def add_project():
    title = request.form.get("title", "").strip()
    sector = request.form.get("sector", "").strip()
    summary = request.form.get("summary", "").strip()
    image_url = request.form.get("image_url", "").strip() or (
