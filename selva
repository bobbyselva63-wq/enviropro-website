    if title and sector and summary:
        db = get_db()
        db.execute(
            "INSERT INTO projects (title, sector, summary, image_url, created_at) "
            "VALUES (?, ?, ?, ?, ?)",
            (title, sector, summary, image_url, datetime.utcnow().isoformat()),
        )
        db.commit()
        flash("Project added.", "success")
    else:
        flash("Title, sector, and summary are required.", "error")
    return redirect(url_for("admin_dashboard"))


